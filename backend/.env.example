# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/cre8

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Payment Gateway (Future Implementation)
PAYMENT_API_KEY=your_payment_gateway_key

# MTN MoMo Sandbox — get credentials at momodeveloper.mtn.com
# 1. Create account & subscribe to Collections + Disbursements
# 2. Copy your subscription keys below
# 3. Run: node provisionMTN.js  (generates MTN_USER_ID + MTN_API_KEY)
MTN_SUBSCRIPTION_KEY=your_collections_subscription_key
MTN_DISBURSEMENTS_SUBSCRIPTION_KEY=your_disbursements_subscription_key
MTN_USER_ID=your_provisioned_user_id
MTN_API_KEY=your_provisioned_api_key
MTN_TARGET_ENVIRONMENT=sandbox
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_CALLBACK_URL=https://YOUR-BACKEND-DOMAIN.com/api/payments/mtn-webhook
